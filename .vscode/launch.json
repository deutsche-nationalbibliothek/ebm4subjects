{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File with Arguments",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "python": "/home/maximilian/.conda/envs/rag-w-gnd/bin/python",
      "cwd": "${workspaceFolder}",
      "args": [
        "--chunks", "results/test/chunks.txt",
        "--chunk_index", "results/test/chunk_index.arrow",
        "--chunk_emnbeddings", "results/test/chunk_embeddings.pkl",
        "--alpha", "0.5",
        "--top_k", "100",
        "--n_hits", "20",
        "--n_jobs", "4",
        "--output", "results/test/candidates1.arrow"
      ]
    }
  ]
}